{
  "name": "pnpm-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint --fix \"**/*.{ts,js}\"",
    "format": "prettier --write .",
    "prepare": "husky",
    "commit": "git-cz",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "utility": "pnpm --filter @pnpm-monorepo/utility",
    "types-utility": "pnpm --filter @pnpm-monorepo/types-utility",
    "docs": "pnpm --filter @pnpm-monorepo/docs dev",
    "docs:dev": "pnpm --filter @pnpm-monorepo/docs dev",
    "docs:build": "pnpm --filter @pnpm-monorepo/docs build",
    "vue-template": "pnpm --filter @pnpm-monorepo/vue-template"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.16.1"
  },
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^19.2.0",
    "@commitlint/config-conventional": "^19.1.0",
    "@commitlint/cz-commitlint": "^19.2.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@vitest/coverage-v8": "^1.4.0",
    "dotenv": "^16.4.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "git-cz": "^4.9.0",
    "husky": "^9.0.11",
    "inquirer": "9",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "taze": "^0.13.3",
    "tsx": "^4.7.2",
    "vue": "^3.4.21"
  }
}
